<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vault — PassVault</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Navbar -->
  <nav class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/vault" class="text-xl font-bold text-indigo-600">🔐 PassVault</a>
      <div class="flex items-center gap-4">
        <span class="text-sm text-gray-500"><%= user.email %></span>
        <form action="/auth/logout" method="POST">
          <button class="text-sm text-red-500 hover:text-red-700">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">My Vault</h1>
      <button 
        onclick="document.getElementById('modal-add').classList.remove('hidden')"
        class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition"
      >
        + Tambah Entry
      </button>
    </div>

    <!-- List entries -->
    <% if (entries.length === 0) { %>
      <div class="text-center py-16 text-gray-400">
        <p class="text-4xl mb-3">🔒</p>
        <p class="text-lg font-medium">Vault kamu masih kosong</p>
        <p class="text-sm">Tambahkan password pertamamu!</p>
      </div>
    <% } else { %>
      <div class="grid gap-3">
        <% entries.forEach(entry => { %>
          <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 flex justify-between items-center">
            <div>
              <p class="font-medium text-gray-800"><%= entry.service_name %></p>
              <p class="text-sm text-gray-500"><%= entry.username %></p>
              <% if (entry.category) { %>
                <span class="text-xs bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-full">
                  <%= entry.category %>
                </span>
              <% } %>
            </div>
            <div class="flex gap-2">
              <button 
                onclick="viewPassword(<%= entry.id %>)"
                class="text-sm text-indigo-600 hover:underline"
              >
                Lihat Password
              </button>
              <button 
                onclick="deleteEntry(<%= entry.id %>)"
                class="text-sm text-red-500 hover:underline"
              >
                Hapus
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </main>

  <!-- Modal Tambah Entry -->
  <div id="modal-add" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl">
      <h2 class="text-lg font-bold text-gray-800 mb-4">Tambah Password Baru</h2>
      <form action="/vault" method="POST">
        <div class="mb-3">
          <label class="block text-sm font-medium text-gray-700 mb-1">Nama Layanan *</label>
          <input type="text" name="service_name" required
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            placeholder="Gmail, Tokopedia, dll">
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium text-gray-700 mb-1">URL</label>
          <input type="url" name="service_url"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            placeholder="https://gmail.com">
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium text-gray-700 mb-1">Username / Email</label>
          <input type="text" name="username"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium text-gray-700 mb-1">Password *</label>
          <input type="password" name="password" required
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </div>
        <div class="mb-5">
          <label class="block text-sm font-medium text-gray-700 mb-1">Kategori</label>
          <input type="text" name="category"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
            placeholder="email, sosmed, kerja, dll">
        </div>
        <div class="flex gap-2">
          <button type="submit"
            class="flex-1 bg-indigo-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
            Simpan
          </button>
          <button type="button"
            onclick="document.getElementById('modal-add').classList.add('hidden')"
            class="flex-1 border border-gray-300 text-gray-600 py-2 rounded-lg text-sm hover:bg-gray-50 transition">
            Batal
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Lihat Password -->
  <div id="modal-view" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
    <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl">
      <h2 class="text-lg font-bold text-gray-800 mb-4">Password</h2>
      <div class="bg-gray-50 rounded-lg px-4 py-3 font-mono text-sm text-gray-800 break-all" id="password-display">
        ...
      </div>
      <button 
        onclick="document.getElementById('modal-view').classList.add('hidden')"
        class="mt-4 w-full border border-gray-300 text-gray-600 py-2 rounded-lg text-sm hover:bg-gray-50 transition">
        Tutup
      </button>
    </div>
  </div>

  <script>
    async function viewPassword(id) {
      const res = await fetch(`/vault/${id}`);
      const data = await res.json();
      document.getElementById('password-display').textContent = data.password;
      document.getElementById('modal-view').classList.remove('hidden');
    }

    async function deleteEntry(id) {
      if (!confirm('Yakin hapus entry ini?')) return;
      await fetch(`/vault/${id}`, { method: 'DELETE' });
      location.reload();
    }
  </script>

</body>
</html>